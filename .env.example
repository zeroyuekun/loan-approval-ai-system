# =============================================================================
# .env.example — copy to .env and fill in the <REQUIRED> values.
# Never commit a real .env. This file is safe to commit.
# =============================================================================

# ---- Django (Required) ----
DJANGO_SECRET_KEY=<REQUIRED — generate with: python -c "import secrets; print(secrets.token_urlsafe(50))">
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Django admin URL path (randomize in production, e.g. "my-secret-admin/")
DJANGO_ADMIN_URL=admin/
# Django superuser password used by some seeding scripts
DJANGO_SUPERUSER_PASSWORD=<OPTIONAL — admin password for seeded superuser>

# ---- Database (Required) ----
POSTGRES_DB=loan_approval
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<REQUIRED>
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ---- Redis / Celery (Required) ----
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=<OPTIONAL — empty for local Docker; required in production>
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=django-db
DJANGO_CACHE_URL=redis://redis:6379/1

# ---- Field encryption (Required) ----
# Generate via: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=<REQUIRED — 44-char base64 Fernet key>

# ---- Claude / Anthropic API (Required for email generation; tests use sk-ant-test-key) ----
ANTHROPIC_API_KEY=<REQUIRED — sk-ant-...>
ANTHROPIC_DAILY_BUDGET_USD=5.00

# ---- Health check token (Optional — restricts /health/deep/; empty = open in dev) ----
HEALTH_CHECK_TOKEN=

# ---- Sentry (Optional — leave empty to disable) ----
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ---- Email / SMTP (Optional — needed for outbound emails in dev) ----
# Gmail SMTP — generate an App Password at https://myaccount.google.com/apppasswords
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=aussieloanai@gmail.com

# ---- Frontend (Required for browser features) ----
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_ACL_NUMBER=DEMO-LENDER-000000
NEXT_PUBLIC_ABN=00 000 000 000
NEXT_PUBLIC_SENTRY_DSN=

# ---- CORS (Required if frontend served from a different origin) ----
CORS_ALLOWED_ORIGINS=http://localhost:3000
